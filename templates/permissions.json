{
  "description": "Agent/Skillが使うパーミッション一覧（単一ソース）",
  "permissions": {
    "core": {
      "description": "全Agent共通: ファイル操作・探索",
      "allow": [
        "Read",
        "Write",
        "Bash(cat:*)",
        "Bash(find:*)",
        "Bash(grep:*)",
        "Bash(ls:*)"
      ]
    },
    "vcs": {
      "description": "バージョン管理・GitHub連携",
      "allow": [
        "Bash(git:*)",
        "Bash(gh:*)"
      ]
    },
    "languages": {
      "go":         ["Bash(go:*)"],
      "rust":       ["Bash(cargo:*)"],
      "python":     ["Bash(python:*)", "Bash(pytest:*)"],
      "nodejs":     ["Bash(npm:*)", "Bash(npx:*)"],
      "yarn":       ["Bash(yarn:*)"],
      "pnpm":       ["Bash(pnpm:*)"],
      "make":       ["Bash(make:*)"]
    }
  }
}
